{
  "name": "claude-notifier",
  "version": "1.0.0",
  "description": "Notificaciones nativas (sonido + popup) para Claude Code, Windows y Linux",
  "main": "dist/notifier.js",
  "scripts": {
    "build": "tsc",
    "setup": "ts-node scripts/setup.ts",
    "test:sound": "ts-node src/notifier.ts task_done",
    "test:waiting": "ts-node src/notifier.ts waiting_input",
    "test:permission": "ts-node src/notifier.ts waiting_permission",
    "start": "node dist/notifier.js"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-notifier": "^8.0.5",
    "@types/play-sound": "^1.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "node-notifier": "^10.0.1",
    "play-sound": "^1.1.6"
  }
}
